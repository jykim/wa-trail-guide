<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>WA Trail Finder</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
  .pill { cursor: pointer; user-select: none; transition: all .15s; }
  .pill[aria-pressed="true"] { box-shadow: inset 0 0 0 2px currentColor; }
  .access-open { background: #ecfdf5; color: #065f46; }
  .access-snow_gear { background: #fffbeb; color: #92400e; }
  .access-closed { background: #fef2f2; color: #991b1b; }
  .access-unknown { background: #f3f4f6; color: #4b5563; }
  .access-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; vertical-align: 1px; }
  .access-dot.open      { background: #10b981; }
  .access-dot.snow_gear { background: #f59e0b; }
  .access-dot.closed    { background: #ef4444; }
  .access-dot.unknown   { background: #9ca3af; }
  .field-icon { width: 14px; height: 14px; display: inline-block; vertical-align: -2px; margin-right: 4px; }
  #map { width: 100%; height: 100%; min-height: 420px; }
  /* Tailwind preflight clamps img max-width and forces border-box on everything,
   * which breaks Leaflet's tile and marker positioning math. Reset to the defaults
   * Leaflet expects inside the map container. */
  .leaflet-container img,
  .leaflet-container .leaflet-tile,
  .leaflet-container .leaflet-marker-icon,
  .leaflet-container .leaflet-marker-shadow,
  .leaflet-container .leaflet-image-layer {
    max-width: none !important;
    max-height: none !important;
  }
  .leaflet-container,
  .leaflet-container *,
  .leaflet-container *::before,
  .leaflet-container *::after {
    box-sizing: content-box;
  }
  .leaflet-container img {
    display: inline;
    height: auto;
  }
  .marker-dot {
    width: 18px; height: 18px; border-radius: 50%;
    border: 2px solid white; box-shadow: 0 0 0 1px rgba(0,0,0,0.3);
  }
  .marker-dot.marker-fresh {
    box-shadow: 0 0 0 2px #1f2937;
  }
  .marker-open      { background: #10b981; }
  .marker-snow_gear { background: #f59e0b; }
  .marker-closed    { background: #ef4444; }
  .marker-unknown   { background: #9ca3af; }
  .marker-tri {
    width: 10px; height: 10px;
    background: currentColor;
    border: 1.5px solid white;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.4);
  }
  .tri-NPS         { color: #7c3aed; }   /* purple */
  .tri-USFS        { color: #15803d; }   /* dark green */
  .tri-StateParks  { color: #0369a1; }   /* blue */
  .tri-Other       { color: #6b7280; }
  .marker-stop {
    width: 22px; height: 22px; border-radius: 50%;
    background: white; border: 2px solid #1f2937;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; line-height: 1;
  }
  .marker-stop.stop-rest_area  { border-color: #1d4ed8; }
  .marker-stop.stop-truck_stop { border-color: #b91c1c; }
  .marker-or {
    width: 12px; height: 12px; border-radius: 50%;
    background: #2563eb;
    border: 2px solid white;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.4);
  }
  .leaflet-popup-content .popup-link { color: #1d4ed8; text-decoration: underline; }
  .leaflet-popup-content { margin: 8px 12px; font-size: 13px; line-height: 1.4; }
  .leaflet-popup-content .popup-title { font-weight: 600; font-size: 14px; }
  .leaflet-popup-content .popup-region { color: #6b7280; font-size: 11px; }
</style>
</head>
<body class="bg-slate-50 text-slate-900">
<div x-data='dashboard()' x-init='init()' class="lg:fixed lg:inset-0 flex flex-col">

  <header class="flex items-baseline gap-3 px-4 py-2 border-b border-slate-200 bg-white flex-shrink-0">
    <h1 class="text-base font-semibold tracking-tight whitespace-nowrap">
      <a href="/" class="hover:text-blue-700" title="Reset filters">WA Trail Finder</a>
    </h1>
    <span class="text-xs text-slate-500 truncate">{{ trail_count }} trails · updated {{ generated_at }}</span>
    <button @click="openHelpModal()"
            class="ml-auto w-6 h-6 rounded-full border border-slate-300 text-slate-600 hover:bg-slate-100 hover:text-blue-700 text-xs font-semibold flex items-center justify-center flex-shrink-0"
            title="Help — basics, adding trails, support">?</button>
    <button @click="openUpdatesModal()"
            class="text-xs px-2.5 py-1 rounded border border-blue-300 bg-blue-50 text-blue-800 hover:bg-blue-100 flex items-center gap-1.5 whitespace-nowrap"
            title="Get weekly trail updates by email">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      Get trail updates
    </button>
  </header>

  <!-- Help modal -->
  <div x-show="helpModalOpen"
       x-transition.opacity
       @keydown.escape.window="closeHelpModal()"
       class="fixed inset-0 z-[2000] flex items-center justify-center bg-black/40 px-4"
       style="display: none;">
    <div @click.outside="closeHelpModal()"
         class="bg-white rounded-xl shadow-xl border border-slate-200 w-full max-w-md p-5 max-h-[85vh] overflow-y-auto">
      <div class="flex items-start justify-between gap-2 mb-3">
        <h2 class="text-base font-semibold text-slate-900">How to use WA Trail Finder</h2>
        <button @click="closeHelpModal()"
                class="text-slate-400 hover:text-slate-700 text-lg leading-none -mt-0.5"
                title="Close">×</button>
      </div>

      <div class="space-y-4 text-sm text-slate-700">
        <div class="flex items-start gap-2 rounded-lg bg-amber-50 border border-amber-200 px-3 py-2 text-xs text-amber-900">
          <span aria-hidden="true">⚠️</span>
          <p>Trail status is <span class="font-semibold">AI-generated</span> from recent trip reports and may be wrong or out of date — always double-check <a href="https://www.wta.org" target="_blank" rel="noopener" class="underline font-medium">wta.org</a> before heading out.</p>
        </div>

        <div>
          <h3 class="font-semibold text-slate-900 mb-1">The basics</h3>
          <ul class="list-disc pl-5 space-y-1 text-xs text-slate-600">
            <li>Each card and map marker is a Washington hiking trail. The colored pill shows its current accessibility:
              <span class="font-medium text-emerald-700">Open</span>,
              <span class="font-medium text-amber-700">Snow gear</span>,
              <span class="font-medium text-red-700">Closed</span>, or
              <span class="font-medium text-slate-500">Stale</span> (no recent reports).</li>
            <li>Use the filters up top — Status, Region, Drive time, Sort — and the search box to narrow the list.</li>
            <li><span class="font-medium">Drive times</span> are approximate, measured from <span class="font-medium">Bellevue</span> and <span class="font-medium">Seattle</span> without traffic — treat them as a rough baseline, not live ETAs.</li>
            <li>Click a card to zoom its marker on the map. Toggle the <span class="font-medium">Camps</span> and <span class="font-medium">Stops</span> layers to show campgrounds and rest areas.</li>
            <li><span class="font-medium">Recent updates</span> lists trails whose status changed in the last 7 days.</li>
          </ul>
        </div>

        <div>
          <h3 class="font-semibold text-slate-900 mb-1">Add a new trail</h3>
          <ol class="list-decimal pl-5 space-y-1 text-xs text-slate-600">
            <li>Type the trail name in the search box.</li>
            <li>Click <span class="font-medium">"Search wta.org for …"</span> below the results (it appears whether or not local trails matched).</li>
            <li>Click <span class="font-medium">Add</span> next to the trail you want. We fetch the trail, pull its recent trip reports, and summarize them — this takes about 20 seconds, then the map refreshes with it included.</li>
          </ol>
        </div>

        <div>
          <h3 class="font-semibold text-slate-900 mb-1">How often it updates</h3>
          <ul class="list-disc pl-5 space-y-1 text-xs text-slate-600">
            <li><span class="font-medium">Daily (~3am PT)</span> — a quick pass re-checks trails that aren't currently Open (snow gear / closed), so newly-opened trails surface fast.</li>
            <li><span class="font-medium">Fridays (~3am PT)</span> — a full refresh re-checks every trail plus the regional rankings.</li>
          </ul>
          <p class="text-[11px] text-slate-500 mt-1">The "updated" time in the header shows when the trail data was last refreshed.</p>
        </div>

        <div>
          <h3 class="font-semibold text-slate-900 mb-1">Support &amp; more</h3>
          <p class="text-xs text-slate-600">
            Questions, problems, or suggestions? Email
            <a href="mailto:lifidea@gmail.com" class="text-blue-700 underline">lifidea@gmail.com</a>.
          </p>
          <p class="text-xs text-slate-600 mt-1">
            See <a href="/about.html" class="text-blue-700 underline">About</a> for how data is collected and what each icon means.
          </p>
        </div>

        <div class="border-t border-slate-200 pt-4">
          <div class="flex items-center gap-2 mb-1">
            <h3 class="font-semibold text-slate-900">Get trail updates</h3>
            <span class="text-[10px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded bg-amber-100 text-amber-800">Coming soon</span>
          </div>
          <template x-if="!updatesSubmitted">
            <div>
              <p class="text-xs text-slate-600 mb-2">
                Weekly email digest of trail status changes is on the way. Leave your email and we'll let you know when it launches.
              </p>
              <form @submit.prevent="submitUpdatesEmail()" class="flex gap-2">
                <input type="email" x-model="updatesEmail" required
                       placeholder="you@example.com"
                       class="flex-1 min-w-0 text-sm border border-slate-300 rounded px-2.5 py-1.5 bg-white focus:outline-none focus:ring-1 focus:ring-blue-400" />
                <button type="submit"
                        :disabled="updatesSubmitting"
                        class="text-sm px-3 py-1.5 rounded bg-blue-600 text-white hover:bg-blue-700 font-medium disabled:opacity-60 disabled:cursor-not-allowed whitespace-nowrap">
                  <span x-text="updatesSubmitting ? 'Saving…' : 'Notify me'"></span>
                </button>
              </form>
              <p x-show="updatesError" class="text-xs text-red-700 mt-1" x-text="updatesError"></p>
            </div>
          </template>
          <template x-if="updatesSubmitted">
            <p class="text-xs text-slate-600">
              <span class="font-medium text-emerald-700">Thanks! ✓</span>
              We'll email <span class="font-medium" x-text="updatesEmail"></span> when trail updates launch.
            </p>
          </template>
        </div>
      </div>

      <div class="mt-4 text-right">
        <button @click="closeHelpModal()"
                class="text-sm px-3 py-1.5 rounded bg-blue-600 text-white hover:bg-blue-700 font-medium">Got it</button>
      </div>
    </div>
  </div>

  <!-- Get trail updates modal (email collection · feature TBA) -->
  <div x-show="updatesModalOpen"
       x-transition.opacity
       @keydown.escape.window="closeUpdatesModal()"
       class="fixed inset-0 z-[2000] flex items-center justify-center bg-black/40 px-4"
       style="display: none;">
    <div @click.outside="closeUpdatesModal()"
         class="bg-white rounded-xl shadow-xl border border-slate-200 w-full max-w-sm p-5">
      <div class="flex items-start justify-between gap-2 mb-1">
        <h2 class="text-sm font-semibold text-slate-900">Get trail updates</h2>
        <button @click="closeUpdatesModal()"
                class="text-slate-400 hover:text-slate-700 text-lg leading-none -mt-0.5"
                title="Close">×</button>
      </div>
      <span class="inline-block text-[10px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded bg-amber-100 text-amber-800 mb-2">Coming soon</span>

      <template x-if="!updatesSubmitted">
        <div>
          <p class="text-xs text-slate-600 mb-3">
            Weekly email digest of trail status changes is on the way. Leave your email and we'll let you know when it launches.
          </p>
          <form @submit.prevent="submitUpdatesEmail()" class="flex flex-col gap-2">
            <input type="email" x-model="updatesEmail" required
                   x-ref="updatesEmailInput"
                   placeholder="you@example.com"
                   class="text-sm border border-slate-300 rounded px-2.5 py-1.5 bg-white focus:outline-none focus:ring-1 focus:ring-blue-400" />
            <button type="submit"
                    :disabled="updatesSubmitting"
                    class="text-sm px-3 py-1.5 rounded bg-blue-600 text-white hover:bg-blue-700 font-medium disabled:opacity-60 disabled:cursor-not-allowed">
              <span x-text="updatesSubmitting ? 'Saving…' : 'Notify me'"></span>
            </button>
            <p x-show="updatesError" class="text-xs text-red-700" x-text="updatesError"></p>
          </form>
        </div>
      </template>

      <template x-if="updatesSubmitted">
        <div class="text-sm text-slate-700 py-2">
          <p class="font-medium text-emerald-700 mb-1">Thanks! ✓</p>
          <p class="text-xs text-slate-600">We'll email <span class="font-medium" x-text="updatesEmail"></span> when trail updates launch.</p>
        </div>
      </template>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 px-4 py-2 border-b border-slate-200 bg-white flex-shrink-0">

    <div class="flex items-center gap-1">
      <span class="text-xs font-medium text-slate-600 mr-1">Status:</span>
      <button class="pill px-2.5 py-1 rounded-full text-xs font-medium bg-slate-200 text-slate-700"
              :aria-pressed="access === 'all'" @click="access = 'all'">
        All <span class="opacity-70" x-text="'(' + trails.length + ')'"></span>
      </button>
      <template x-for="opt in accessOptions" :key="opt.value">
        <button class="pill px-2.5 py-1 rounded-full text-xs font-medium"
                :class="'access-' + opt.value"
                :aria-pressed="access === opt.value"
                @click="access = opt.value">
          <span x-text="opt.label"></span>
          <span class="ml-0.5 opacity-70" x-text="'(' + countBy('accessibility', opt.value) + ')'"></span>
        </button>
      </template>
    </div>

    <div class="flex items-center gap-1">
      <span class="text-xs font-medium text-slate-600">Region:</span>
      <select x-model="region" class="text-xs border border-slate-300 rounded px-2 py-1 bg-white max-w-[200px]">
        <option value="all">All regions</option>
        <template x-for="r in regions" :key="r">
          <option :value="r" x-text="r"></option>
        </template>
      </select>
    </div>

    <div class="flex items-center gap-1">
      <span class="text-xs font-medium text-slate-600">Drive:</span>
      <select x-model.number="maxDrive" class="text-xs border border-slate-300 rounded px-2 py-1 bg-white">
        <option value="0">Any</option>
        <option value="60">≤ 1h</option>
        <option value="120">≤ 2h</option>
        <option value="180">≤ 3h</option>
        <option value="240">≤ 4h</option>
        <option value="300">≤ 5h</option>
      </select>
    </div>

    <div class="flex items-center gap-1">
      <span class="text-xs font-medium text-slate-600">Sort:</span>
      <select x-model="sort" class="text-xs border border-slate-300 rounded px-2 py-1 bg-white">
        <option value="rating">Rating</option>
        <option value="recent">Most recent</option>
        <option value="drive">Drive time</option>
        <option value="volume">Volume</option>
        <option value="name">Name (A–Z)</option>
      </select>
    </div>

    <div class="flex items-center gap-1">
      <input type="search" x-model="query"
             placeholder="Search trail name…"
             class="text-xs border border-slate-300 rounded px-2 py-1 bg-white w-44 focus:outline-none focus:ring-1 focus:ring-blue-400" />
      <button x-show="query" @click="query = ''"
              class="text-xs text-slate-500 hover:text-slate-800"
              title="Clear">×</button>
    </div>

    <div class="flex items-center gap-1">
      <span class="text-xs font-medium text-slate-600">Layers:</span>
      <button class="pill px-2.5 py-1 rounded-full text-xs font-medium border border-slate-300 bg-white text-slate-700 flex items-center gap-1"
              :class="showCamps ? 'bg-purple-100 text-purple-900 border-purple-300' : ''"
              :aria-pressed="showCamps"
              @click="showCamps = !showCamps"
              title="Toggle public campground markers">
        <span class="inline-block" style="width:8px;height:8px;background:currentColor;border:1.5px solid white;box-shadow:0 0 0 1px rgba(0,0,0,0.35);"></span>
        Camps <span class="opacity-70" x-text="'(' + campgrounds.length + ')'"></span>
      </button>
      <button class="pill px-2.5 py-1 rounded-full text-xs font-medium border border-slate-300 bg-white text-slate-700 flex items-center gap-1"
              :class="showStops ? 'bg-blue-100 text-blue-900 border-blue-300' : ''"
              :aria-pressed="showStops"
              @click="showStops = !showStops"
              title="Toggle rest areas and truck stops">
        <span>🚗</span>
        Stops <span class="opacity-70" x-text="'(' + restAreas.length + ')'"></span>
      </button>
    </div>

    <span class="ml-auto text-xs text-slate-500" x-text="visibleCount() + ' shown'"></span>
  </div>

  <!-- Cards (left, resizable + collapsible) + Map (right, full height) -->
  <main class="flex-1 lg:min-h-0 flex flex-col lg:flex-row"
        :style="`--left-width: ${leftWidth}px`">

    <!-- Cards pane -->
    <section x-show="!collapsed"
             class="order-last lg:order-first flex flex-col gap-3 w-full lg:w-[var(--left-width)] lg:min-w-[260px] lg:max-w-[70vw] lg:shrink-0 lg:overflow-y-auto p-3 lg:py-3 lg:pl-4 lg:pr-3">
      <div class="hidden lg:flex items-center justify-end -mb-1">
        <button @click="toggleCollapse"
                class="px-2 py-1 rounded text-xs text-slate-500 hover:text-slate-900 hover:bg-slate-100"
                title="Hide list">⟨ Hide</button>
      </div>

      <!-- Recent status changes (collapsed by default; click header to expand) -->
      <div x-show="updates().length > 0"
           class="bg-amber-50 border border-amber-200 rounded-lg overflow-hidden mb-2 shadow-sm shrink-0">
        <!-- Clickable header row (div, not <button>, to avoid UA default rendering quirks) -->
        <div @click="showUpdates = !showUpdates"
             role="button" tabindex="0"
             @keydown.enter.prevent="showUpdates = !showUpdates"
             @keydown.space.prevent="showUpdates = !showUpdates"
             :aria-expanded="showUpdates"
             class="cursor-pointer select-none flex items-center gap-2 px-3 py-2 hover:bg-amber-100 transition text-sm">
          <span class="text-amber-700 w-3 text-center leading-none"
                x-text="showUpdates ? '▾' : '▸'"></span>
          <span class="text-xs font-semibold text-amber-900">Recent updates</span>
          <span class="text-[11px] text-amber-700"
                x-text="updates().length + ' trail' + (updates().length === 1 ? '' : 's') + ' · last 7d'"></span>
          <span class="ml-auto text-[10px] text-amber-700"
                x-show="!showUpdates">click to expand</span>
        </div>
        <!-- Expanded body: rows sorted newest-first -->
        <div x-show="showUpdates" class="px-3 pb-3 border-t border-amber-200">
          <div class="flex flex-col gap-1 mt-2">
          <template x-for="u in updates()" :key="u.slug">
            <div class="text-xs text-slate-800 flex items-baseline gap-1.5 flex-wrap">
              <a :href="u.url" target="_blank" rel="noopener" class="font-medium hover:text-blue-700" x-text="u.name"></a>
              <!-- Accessibility (status) flip: prev → current -->
              <span class="text-slate-500">
                <span class="access-dot" :class="u.status.prev_accessibility || 'unknown'"></span>
                <span x-text="accessLabel(u.status.prev_accessibility)"></span>
                <span class="text-slate-400">→</span>
                <span class="access-dot" :class="u.status.accessibility || 'unknown'"></span>
                <span x-text="accessLabel(u.status.accessibility)"></span>
              </span>
              <span class="text-[10px] text-slate-400"
                    :title="u.status.last_report_date ? ('Status from report dated ' + u.status.last_report_date) : ''"
                    x-text="u.status.days_since_report == null ? '' : ('· ' + (u.status.days_since_report === 0 ? 'today' : u.status.days_since_report + 'd ago'))"></span>
            </div>
          </template>
          </div>
          <div class="mt-2 pt-2 border-t border-amber-200">
            <a href="/about.html#status"
               class="text-[11px] text-amber-800 hover:text-amber-900 underline">How status is determined →</a>
          </div>
        </div>
      </div>

    <template x-for="t in visible()" :key="t.slug">
      <div class="bg-white rounded-lg shadow-sm border p-4 flex flex-col cursor-pointer hover:border-blue-300 hover:shadow transition"
           :class="focusedSlug === t.slug ? 'border-blue-500 ring-2 ring-blue-200' : 'border-slate-200'"
           @click="focusTrail(t)">

        <div class="flex items-start justify-between gap-2 mb-1">
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline gap-1.5 flex-wrap">
              <a :href="t.url" target="_blank" rel="noopener"
                 @click.stop
                 class="font-semibold text-slate-900 hover:text-blue-700" x-text="t.name"></a>
              <a x-show="t.lat != null && t.lng != null"
                 :href="'https://www.google.com/maps/search/?api=1&query=' + t.lat + ',' + t.lng"
                 target="_blank" rel="noopener"
                 @click.stop
                 class="text-[11px] text-blue-600 hover:text-blue-800"
                 title="Open trailhead in Google Maps">📍 Maps</a>
            </div>
            <div class="text-xs text-slate-500" x-text="t.region + (t.subregion ? ' › ' + t.subregion : '')"></div>
          </div>
          <div class="flex items-center gap-1 whitespace-nowrap">
            <span x-show="t.status.is_recently_changed"
                  class="text-[10px] px-1.5 py-0.5 rounded-full font-semibold"
                  :class="{
                    'bg-emerald-100 text-emerald-800': t.status.change_reason === 'new',
                    'bg-blue-100 text-blue-800':       t.status.change_reason === 'new_report',
                    'bg-amber-100 text-amber-800':     !t.status.change_reason || t.status.change_reason === 'accessibility' || t.status.change_reason === 'summary'
                  }"
                  :title="updateBadgeTitle(t)"
                  x-text="updateBadgeLabel(t)">
            </span>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium"
                  :class="t.status.is_stale ? 'access-unknown' : 'access-' + (t.status.accessibility || 'unknown')"
                  x-text="t.status.is_stale ? 'Stale' : accessLabel(t.status.accessibility)"></span>
          </div>
        </div>

        <div class="text-xs text-slate-500 mb-2">
          <span x-text="'★ ' + t.rating.toFixed(2)"></span>
          ·
          <span x-text="t.votes + ' votes'"></span>
          <template x-if="t.length_miles">
            <span> · <span x-text="t.length_miles + ' mi'"></span></span>
          </template>
          <template x-if="t.elev_gain_ft">
            <span> · <span x-text="(t.elev_gain_ft || 0).toLocaleString() + ' ft gain'"></span></span>
          </template>
        </div>

        <div class="text-xs text-slate-500 mb-2 flex flex-wrap gap-x-3" x-show="t.drive_seattle_min || t.drive_bellevue_min">
          <span x-show="t.drive_bellevue_min">
            <span class="text-slate-400">BVE</span> <span x-text="formatDrive(t.drive_bellevue_min)"></span><span x-show="t.drive_bellevue_mi" class="text-slate-400" x-text="' · ' + t.drive_bellevue_mi + 'mi'"></span>
          </span>
          <span x-show="t.drive_seattle_min">
            <span class="text-slate-400">SEA</span> <span x-text="formatDrive(t.drive_seattle_min)"></span><span x-show="t.drive_seattle_mi" class="text-slate-400" x-text="' · ' + t.drive_seattle_mi + 'mi'"></span>
          </span>
        </div>

        <p class="text-sm text-slate-700 mb-3" x-text="t.status.summary"></p>

        <div class="grid grid-cols-2 gap-x-3 gap-y-1 text-xs text-slate-600 mt-auto">
          <div><span class="text-slate-400">Snow line:</span> <span x-text="t.status.snow_line_ft ? t.status.snow_line_ft.toLocaleString() + ' ft' : '—'"></span></div>
          <div><span class="text-slate-400">Road:</span> <span x-text="t.status.road_status"></span></div>
          <div><span class="text-slate-400">Bugs:</span> <span x-text="t.status.bugs"></span></div>
          <div><span class="text-slate-400">Flowers:</span> <span x-text="t.status.wildflowers"></span></div>
        </div>

        <div class="mt-2 pt-2 border-t border-slate-100 text-xs flex items-center gap-1"
             :class="t.status.is_stale ? 'text-amber-700' : 'text-slate-500'">
          <span x-show="t.status.last_report_date" x-text="'Last report: ' + t.status.last_report_date"></span>
          <span x-show="!t.status.last_report_date">No reports</span>
          <span x-show="t.status.is_stale && t.status.days_since_report"
                x-text="' · ' + t.status.days_since_report + 'd ago'"></span>
        </div>

      </div>
    </template>
      <div x-show="visibleCount() === 0" class="text-slate-500 py-6 px-2">
        <p x-show="!query.trim()" class="text-center">No trails match the current filters.</p>
        <p x-show="query.trim()" class="text-center text-sm">
          No local match for "<span class="font-medium" x-text="query"></span>".
        </p>
      </div>

      <!-- Search wta.org — available whenever there's a query, even if local trails matched. -->
      <div x-show="query.trim()" class="space-y-3 px-2 pt-1 pb-2">
        <div class="flex justify-center" x-show="remoteState === 'idle' || remoteState === 'error'">
          <button @click="searchWta()"
                  class="px-3 py-1.5 text-xs font-medium rounded border border-blue-300 bg-blue-50 text-blue-800 hover:bg-blue-100">
            <span x-show="visibleCount() > 0">Not listed? </span>Search wta.org for "<span x-text="query"></span>"
          </button>
        </div>
        <p x-show="remoteState === 'searching'" class="text-center text-xs text-slate-500">Searching wta.org…</p>
        <p x-show="remoteState === 'adding'" class="text-center text-xs text-slate-500">Fetching trail · scraping reports · summarizing… (~20s)</p>
        <p x-show="remoteState === 'error'" class="text-center text-xs text-red-700" x-text="remoteError"></p>
        <div x-show="remoteState === 'results' && remoteResults.length === 0" class="text-center text-xs text-slate-500">
          No matches on wta.org.
        </div>
        <div x-show="remoteState === 'results' && remoteResults.length > 0" class="bg-white border border-slate-200 rounded-lg divide-y divide-slate-100">
          <template x-for="r in remoteResults" :key="r.slug">
            <div class="p-2.5 flex items-start gap-2">
              <div class="flex-1 min-w-0">
                <a :href="r.url" target="_blank" rel="noopener" class="text-sm font-medium text-slate-900 hover:text-blue-700" x-text="r.name"></a>
                <div class="text-[11px] text-slate-500" x-text="(r.region || '—') + ' · ★ ' + (r.rating || 0).toFixed(2) + ' · ' + (r.votes || 0) + ' votes'"></div>
              </div>
              <button @click="addRemote(r)"
                      :disabled="alreadyHave(r)"
                      class="text-xs px-2 py-1 rounded bg-emerald-600 text-white hover:bg-emerald-700 whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
                      x-text="alreadyHave(r) ? 'Added' : 'Add'">
              </button>
            </div>
          </template>
        </div>
      </div>

      <div class="text-[10px] text-slate-400 text-center pt-2 pb-1">
        Sourced from <a href="https://www.wta.org" class="underline">wta.org</a> · classified by GPT-4o-mini
      </div>
    </section>

    <!-- Resize handle (desktop only, hidden when collapsed) -->
    <div x-show="!collapsed"
         @mousedown="startResize"
         class="hidden lg:flex items-center justify-center w-2 cursor-col-resize bg-transparent hover:bg-blue-100 active:bg-blue-200 group select-none"
         title="Drag to resize">
      <div class="w-0.5 h-12 bg-slate-300 group-hover:bg-blue-500 rounded transition-colors"></div>
    </div>

    <!-- Map pane (fills full viewport height on lg) -->
    <section class="order-first lg:order-last flex-1 min-w-0 relative h-[420px] lg:h-full">
      <button x-show="collapsed" @click="toggleCollapse"
              class="hidden lg:flex absolute top-2 left-2 z-[1000] items-center gap-1 bg-white shadow rounded px-2 py-1 text-xs text-slate-700 border border-slate-200 hover:bg-slate-50"
              title="Show list">⟩ Show list</button>
      <div id="map"></div>
    </section>

  </main>
</div>

<script id="trail-data" type="application/json">{{ data_json | safe }}</script>

<script>
  function dashboard() {
    const data = JSON.parse(document.getElementById('trail-data').textContent);
    return {
      trails: data.trails,
      regions: data.regions,
      campgrounds: data.campgrounds || [],
      restAreas: data.rest_areas || [],
      oregonTrails: data.oregon_trails || [],
      access: 'all',           // default: show all trails
      region: 'all',
      maxDrive: 0,             // minutes; 0 = no filter
      sort: 'drive',
      query: '',
      remoteResults: [],
      remoteState: 'idle',     // idle | searching | results | adding | error
      remoteError: '',
      helpModalOpen: false,
      updatesModalOpen: false,
      updatesEmail: '',
      updatesSubmitted: false,
      updatesSubmitting: false,
      updatesError: '',
      accessOptions: [
        { value: 'open',       label: 'Open' },
        { value: 'snow_gear',  label: 'Snow gear' },
        { value: 'closed',     label: 'Closed' },
      ],
      _map: null,
      _markersLayer: null,
      _campsLayer: null,
      _stopsLayer: null,
      _oregonLayer: null,
      _markersBySlug: {},
      showCamps: false,
      showStops: false,
      showOregon: false,
      _resizing: false,
      _mobile: false,
      _invalidateFrame: null,
      focusedSlug: '',
      leftWidth: 320,
      collapsed: false,
      showUpdates: false,
      accessLabel(v) {
        return ({ open: 'Open', snow_gear: 'Snow gear', closed: 'Closed' })[v] || 'Unknown';
      },
      _isMobile() {
        return window.matchMedia('(max-width: 1023px)').matches;
      },
      formatDrive(min) {
        if (min == null) return '';
        const h = Math.floor(min / 60), m = min % 60;
        return h ? `${h}h ${m}m` : `${m}m`;
      },
      minDrive(t) {
        const a = t.drive_seattle_min, b = t.drive_bellevue_min;
        if (a == null && b == null) return null;
        if (a == null) return b;
        if (b == null) return a;
        return Math.min(a, b);
      },
      init() {
        this.loadPrefs();
        const initialQ = new URLSearchParams(window.location.search).get('q');
        if (initialQ) this.query = initialQ;
        this.initMap();
        // Flex container can finish layout after initMap — re-measure once.
        requestAnimationFrame(() => this._map && this._map.invalidateSize());
        this._mobile = this._isMobile();
        window.addEventListener('resize', () => {
          if (this._map) this._map.invalidateSize();
          // Redraw markers only when we cross the mobile/desktop breakpoint (marker size changes).
          const m = this._isMobile();
          if (m !== this._mobile) {
            this._mobile = m;
            this.drawMarkers();
          }
        });
        // Redraw markers whenever filters change. Clear any focused trail first so the
        // map always refits to the new visible set (the focus guard in drawMarkers would
        // otherwise suppress the refit when the focused trail is still visible).
        const refit = () => { this.focusedSlug = ''; this.drawMarkers(); };
        this.$watch('access', refit);
        this.$watch('region', refit);
        this.$watch('maxDrive', refit);
        this.$watch('showCamps', () => {
          this.toggleCamps();
          this.savePrefs();
        });
        this.$watch('showStops', () => {
          this.toggleStops();
          this.savePrefs();
        });
        this.$watch('showOregon', () => {
          this.toggleOregon();
          this.savePrefs();
        });
        this.$watch('showUpdates', () => this.savePrefs());
        this.$watch('query', (v) => {
          this.focusedSlug = '';
          this.drawMarkers();
          this.remoteState = 'idle';
          this.remoteResults = [];
          this.remoteError = '';
          const url = new URL(window.location.href);
          if (v && v.trim()) url.searchParams.set('q', v.trim());
          else url.searchParams.delete('q');
          window.history.replaceState({}, '', url.toString());
        });
        // Layout-state changes -> resize map (and persist).
        this.$watch('collapsed', () => {
          this.savePrefs();
          this.scheduleInvalidate();
        });
        this.$watch('leftWidth', () => {
          this.scheduleInvalidate();
          if (!this._resizing) this.savePrefs();
        });
      },
      loadPrefs() {
        try {
          const w = parseInt(localStorage.getItem('wta-status:left-width'), 10);
          if (!isNaN(w) && w >= 200) {
            this.leftWidth = w;
          } else {
            this.leftWidth = Math.max(260, Math.min(560, Math.round(window.innerWidth * 0.25)));
          }
          this.collapsed = localStorage.getItem('wta-status:collapsed') === '1';
          this.showCamps = localStorage.getItem('wta-status:show-camps') === '1';
          this.showStops = localStorage.getItem('wta-status:show-stops') === '1';
          this.showOregon = localStorage.getItem('wta-status:show-oregon') === '1';
          const upPref = localStorage.getItem('wta-status:show-updates');
          if (upPref !== null) this.showUpdates = upPref === '1';
        } catch (e) {
          this.leftWidth = 320;
        }
      },
      savePrefs() {
        try {
          localStorage.setItem('wta-status:left-width', String(Math.round(this.leftWidth)));
          localStorage.setItem('wta-status:collapsed', this.collapsed ? '1' : '0');
          localStorage.setItem('wta-status:show-camps', this.showCamps ? '1' : '0');
          localStorage.setItem('wta-status:show-stops', this.showStops ? '1' : '0');
          localStorage.setItem('wta-status:show-oregon', this.showOregon ? '1' : '0');
          localStorage.setItem('wta-status:show-updates', this.showUpdates ? '1' : '0');
        } catch (e) {}
      },
      toggleCollapse() {
        this.collapsed = !this.collapsed;
      },
      scheduleInvalidate() {
        if (this._invalidateFrame) return;
        this._invalidateFrame = requestAnimationFrame(() => {
          this._invalidateFrame = null;
          this._map && this._map.invalidateSize();
        });
      },
      startResize(e) {
        e.preventDefault();
        this._resizing = true;
        const startX = e.clientX;
        const startW = this.leftWidth;
        document.body.style.cursor = 'col-resize';
        document.body.style.userSelect = 'none';
        const onMove = (ev) => {
          const dx = ev.clientX - startX;
          const maxW = Math.max(300, window.innerWidth * 0.7);
          this.leftWidth = Math.max(260, Math.min(maxW, startW + dx));
        };
        const onUp = () => {
          this._resizing = false;
          document.body.style.cursor = '';
          document.body.style.userSelect = '';
          window.removeEventListener('mousemove', onMove);
          window.removeEventListener('mouseup', onUp);
          this.savePrefs();
        };
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseup', onUp);
      },
      initMap() {
        // Washington state bounds — fit on first load.
        this._map = L.map('map', { scrollWheelZoom: false }).setView([47.4, -120.7], 7);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 18,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        }).addTo(this._map);
        this._markersLayer = L.layerGroup().addTo(this._map);
        this._campsLayer = L.layerGroup();
        this._stopsLayer = L.layerGroup();
        this._oregonLayer = L.layerGroup();
        // Click-to-enable scroll zoom (avoids hijacking page scroll).
        this._map.on('focus', () => this._map.scrollWheelZoom.enable());
        this._map.on('blur',  () => this._map.scrollWheelZoom.disable());
        this._map.on('popupclose', () => { this.focusedSlug = ''; });
        this.drawMarkers();
        this.drawCamps();
        this.drawStops();
        this.drawOregon();
        if (this.showCamps) this._campsLayer.addTo(this._map);
        if (this.showStops) this._stopsLayer.addTo(this._map);
        if (this.showOregon) this._oregonLayer.addTo(this._map);
      },
      drawMarkers() {
        if (!this._markersLayer) return;
        this._markersLayer.clearLayers();
        this._markersBySlug = {};
        const trails = this.visible().filter(t => t.lat != null && t.lng != null);
        const bounds = [];
        for (const t of trails) {
          const acc = t.status.accessibility || 'unknown';
          const markerClass = t.status.is_stale ? 'unknown' : acc;
          const pillClass = t.status.is_stale ? 'unknown' : acc;
          const pillLabel = t.status.is_stale ? 'Stale' : this.accessLabel(acc);
          const freshClass = t.status.is_fresh ? ' marker-fresh' : '';
          // Shrink to ~campground-marker size on mobile so the map reads less cluttered.
          const dim = this._isMobile() ? 12 : 13;
          const icon = L.divIcon({
            className: '',
            html: `<div class="marker-dot marker-${markerClass}${freshClass}" style="width:${dim}px;height:${dim}px;"></div>`,
            iconSize: [dim, dim],
            iconAnchor: [dim / 2, dim / 2],
          });
          const marker = L.marker([t.lat, t.lng], { icon });
          const dateLine = t.status.is_stale
            ? `<div class="mt-1 text-amber-700 text-xs">Stale${t.status.days_since_report ? ' · ' + t.status.days_since_report + 'd ago' : ''}</div>`
            : '';
          const gmaps = `https://www.google.com/maps/search/?api=1&query=${t.lat},${t.lng}`;
          const popup = `
            <div>
              <div class="popup-title"><a href="${t.url}" target="_blank" rel="noopener">${t.name}</a></div>
              <div class="popup-region">${t.region}${t.subregion ? ' › ' + t.subregion : ''}</div>
              <div class="mt-1"><span class="text-xs px-2 py-0.5 rounded-full font-medium access-${pillClass}">${pillLabel}</span>
                <span class="text-xs text-slate-500 ml-1">★ ${t.rating.toFixed(2)} · ${t.votes} votes</span>
              </div>
              <div class="mt-1 text-slate-700" style="max-width:280px">${t.status.summary || ''}</div>
              ${dateLine}
              <div class="mt-2 flex flex-col gap-1">
                <a class="popup-link" href="${t.url}" target="_blank" rel="noopener">WTA page →</a>
                <a class="popup-link" href="${gmaps}" target="_blank" rel="noopener">Open in Google Maps →</a>
              </div>
            </div>
          `;
          marker.bindPopup(popup);
          marker.addTo(this._markersLayer);
          this._markersBySlug[t.slug] = marker;
          bounds.push([t.lat, t.lng]);
        }
        if (this.focusedSlug && this._markersBySlug[this.focusedSlug]) {
          // Skip auto-fit when the user has picked a specific trail.
        } else if (bounds.length > 0) {
          this._map.fitBounds(bounds, { padding: [40, 40], maxZoom: 10 });
        }
      },
      drawCamps() {
        if (!this._campsLayer) return;
        this._campsLayer.clearLayers();
        const esc = (s) => String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        const truncate = (s, n) => (s && s.length > n) ? s.slice(0, n - 1).trimEnd() + '…' : s;
        const factsRow = (parts) => parts.filter(Boolean).map(esc).join(' · ');
        for (const c of this.campgrounds) {
          if (c.lat == null || c.lng == null) continue;
          const agencyClass = 'tri-' + (c.agency || 'Other').replace(/\s+/g, '');
          const icon = L.divIcon({
            className: '',
            html: `<div class="marker-tri ${agencyClass}"></div>`,
            iconSize: [13, 13],
            iconAnchor: [6, 6],
          });
          const m = L.marker([c.lat, c.lng], { icon });
          const gmaps = `https://www.google.com/maps/search/?api=1&query=${c.lat},${c.lng}`;
          const reserve = `https://www.google.com/search?q=${encodeURIComponent(c.name + ' Washington campground reservation')}`;
          const reservable = c.reservable === 'yes' ? 'Reservable' : c.reservable === 'no' ? 'First-come' : '';
          const facts = factsRow([c.fee, c.season, c.elevation, reservable]);
          const desc = truncate(c.description || '', 220);
          const sitesShort = truncate(c.sites || '', 110);
          const acts = truncate(c.activities || '', 100);
          const popup = `
            <div style="max-width: 300px">
              <div class="popup-title">${esc(c.name)}</div>
              <div class="popup-region">${esc(c.agency || '')}${c.park ? ' · ' + esc(c.park) : ''}</div>
              ${facts ? `<div class="popup-region mt-0.5">${facts}</div>` : ''}
              ${c.location ? `<div class="mt-1 text-slate-600 text-[11px]"><span class="text-slate-400">Location:</span> ${esc(c.location)}</div>` : ''}
              ${desc ? `<div class="mt-1 text-slate-700">${esc(desc)}</div>` : ''}
              ${sitesShort ? `<div class="mt-1 text-slate-600 text-[11px]"><span class="text-slate-400">Sites:</span> ${esc(sitesShort)}</div>` : ''}
              ${c.facilities ? `<div class="mt-0.5 text-slate-600 text-[11px]"><span class="text-slate-400">Facilities:</span> ${esc(truncate(c.facilities, 160))}</div>` : ''}
              ${acts ? `<div class="mt-0.5 text-slate-600 text-[11px]"><span class="text-slate-400">Activities:</span> ${esc(acts)}</div>` : ''}
              ${c.phone ? `<div class="mt-0.5 text-slate-600 text-[11px]"><span class="text-slate-400">Phone:</span> ${esc(c.phone)}</div>` : ''}
              <div class="mt-2 flex flex-col gap-1">
                <a class="popup-link" href="${reserve}" target="_blank" rel="noopener">Reserve / info →</a>
                <a class="popup-link" href="${gmaps}" target="_blank" rel="noopener">Open in Google Maps →</a>
              </div>
              ${c.source && c.source !== 'manual' ? `<div class="mt-1 text-[10px] text-slate-400">Source: ${esc(c.source)}</div>` : ''}
            </div>
          `;
          m.bindPopup(popup);
          m.addTo(this._campsLayer);
        }
      },
      toggleCamps() {
        if (!this._map || !this._campsLayer) return;
        if (this.showCamps) {
          this._campsLayer.addTo(this._map);
        } else {
          this._map.removeLayer(this._campsLayer);
        }
      },
      drawStops() {
        if (!this._stopsLayer) return;
        this._stopsLayer.clearLayers();
        const esc = (s) => String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        for (const s of this.restAreas) {
          if (s.lat == null || s.lng == null) continue;
          const cls = 'stop-' + (s.type || 'rest_area');
          const glyph = s.type === 'truck_stop' ? '🛻' : '🚗';
          const icon = L.divIcon({
            className: '',
            html: `<div class="marker-stop ${cls}">${glyph}</div>`,
            iconSize: [22, 22],
            iconAnchor: [11, 11],
          });
          const m = L.marker([s.lat, s.lng], { icon });
          const gmaps = `https://www.google.com/maps/search/?api=1&query=${s.lat},${s.lng}`;
          const search = `https://www.google.com/search?q=${encodeURIComponent(s.name + ' Washington')}`;
          const typeLabel = s.type === 'truck_stop' ? 'Truck stop' : 'Rest area';
          const popup = `
            <div style="max-width: 280px">
              <div class="popup-title">${esc(s.name)}</div>
              <div class="popup-region">${typeLabel}${s.highway ? ' · ' + esc(s.highway) : ''}</div>
              ${s.amenities ? `<div class="mt-1 text-slate-600 text-[11px]"><span class="text-slate-400">Amenities:</span> ${esc(s.amenities)}</div>` : ''}
              <div class="mt-2 flex flex-col gap-1">
                <a class="popup-link" href="${gmaps}" target="_blank" rel="noopener">Open in Google Maps →</a>
                <a class="popup-link" href="${search}" target="_blank" rel="noopener">Google search →</a>
              </div>
            </div>
          `;
          m.bindPopup(popup);
          m.addTo(this._stopsLayer);
        }
      },
      toggleStops() {
        if (!this._map || !this._stopsLayer) return;
        if (this.showStops) {
          this._stopsLayer.addTo(this._map);
        } else {
          this._map.removeLayer(this._stopsLayer);
        }
      },
      drawOregon() {
        if (!this._oregonLayer) return;
        this._oregonLayer.clearLayers();
        const esc = (s) => String(s == null ? '' : s)
          .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
          .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
        for (const t of this.oregonTrails) {
          if (t.lat == null || t.lng == null) continue;
          const icon = L.divIcon({
            className: '',
            html: `<div class="marker-or"></div>`,
            iconSize: [14, 14],
            iconAnchor: [7, 7],
          });
          const m = L.marker([t.lat, t.lng], { icon });
          const gmaps = `https://www.google.com/maps/search/?api=1&query=${t.lat},${t.lng}`;
          const link = t.url || `https://www.google.com/search?q=${encodeURIComponent(t.name + ' Oregon hike')}`;
          const facts = [
            t.length_miles ? `${t.length_miles} mi` : '',
            t.elev_gain_ft ? `${t.elev_gain_ft.toLocaleString()} ft gain` : '',
            t.difficulty || '',
            t.region || ''
          ].filter(Boolean).map(esc).join(' · ');
          const popup = `
            <div style="max-width: 280px">
              <div class="popup-title">${esc(t.name)}</div>
              <div class="popup-region">Oregon${t.region ? ' · ' + esc(t.region) : ''}</div>
              ${facts ? `<div class="popup-region mt-0.5">${facts}</div>` : ''}
              ${t.season ? `<div class="mt-1 text-slate-600 text-[11px]"><span class="text-slate-400">Season:</span> ${esc(t.season)}</div>` : ''}
              <div class="mt-2 flex flex-col gap-1">
                <a class="popup-link" href="${link}" target="_blank" rel="noopener">Trail info →</a>
                <a class="popup-link" href="${gmaps}" target="_blank" rel="noopener">Open in Google Maps →</a>
              </div>
              ${t.source ? `<div class="mt-1 text-[10px] text-slate-400">Source: ${esc(t.source)}</div>` : ''}
            </div>
          `;
          m.bindPopup(popup);
          m.addTo(this._oregonLayer);
        }
      },
      toggleOregon() {
        if (!this._map || !this._oregonLayer) return;
        if (this.showOregon) {
          this._oregonLayer.addTo(this._map);
        } else {
          this._map.removeLayer(this._oregonLayer);
        }
      },
      focusTrail(t) {
        if (t.lat == null || t.lng == null) return;
        this.focusedSlug = t.slug;
        this._map.setView([t.lat, t.lng], 12, { animate: true });
        const m = this._markersBySlug[t.slug];
        if (m) m.openPopup();
      },
      openHelpModal() {
        this.helpModalOpen = true;
        this.updatesSubmitted = false;
        this.updatesError = '';
      },
      closeHelpModal() {
        this.helpModalOpen = false;
      },
      openUpdatesModal() {
        this.updatesModalOpen = true;
        this.updatesSubmitted = false;
        requestAnimationFrame(() => {
          const el = this.$refs && this.$refs.updatesEmailInput;
          if (el && el.focus) el.focus();
        });
      },
      closeUpdatesModal() {
        this.updatesModalOpen = false;
      },
      async submitUpdatesEmail() {
        const email = (this.updatesEmail || '').trim();
        if (!email) return;
        this.updatesError = '';
        this.updatesSubmitting = true;
        try {
          const resp = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok) throw new Error(data.error || ('HTTP ' + resp.status));
          this.updatesSubmitted = true;
        } catch (e) {
          this.updatesError = 'Could not save your email: ' + e.message;
        } finally {
          this.updatesSubmitting = false;
        }
      },
      async searchWta() {
        const q = (this.query || '').trim();
        if (!q) return;
        this.remoteState = 'searching';
        this.remoteError = '';
        this.remoteResults = [];
        try {
          const resp = await fetch('/api/search?q=' + encodeURIComponent(q));
          if (!resp.ok) throw new Error('HTTP ' + resp.status);
          const data = await resp.json();
          this.remoteResults = data.results || [];
          this.remoteState = 'results';
        } catch (e) {
          this.remoteState = 'error';
          this.remoteError = 'Search failed: ' + e.message + ' (is server.py running?)';
        }
      },
      async addRemote(r) {
        this.remoteState = 'adding';
        this.remoteError = '';
        try {
          const resp = await fetch('/api/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: r.slug, url: r.url }),
          });
          const data = await resp.json();
          if (!resp.ok) throw new Error(data.error || ('HTTP ' + resp.status));
          // Preserve the search query across the reload by pushing it into the URL.
          // Prefer the added trail's name so the new card is guaranteed to match.
          const newQuery = (data && data.name) || this.query;
          const url = new URL(window.location.href);
          if (newQuery) url.searchParams.set('q', newQuery);
          window.location.replace(url.toString());
        } catch (e) {
          this.remoteState = 'error';
          this.remoteError = 'Add failed: ' + e.message;
        }
      },
      updateBadgeTitle(t) {
        const ago = t.status.days_since_change === 0 ? 'today' : t.status.days_since_change + 'd ago';
        switch (t.status.change_reason) {
          case 'new':        return 'Newly added ' + ago;
          case 'new_report': return 'New trip report ' + ago;
          case 'summary':    return 'Summary updated ' + ago;
          default:           return 'Changed from ' + this.accessLabel(t.status.prev_accessibility) + ' ' + ago;
        }
      },
      updateBadgeLabel(t) {
        switch (t.status.change_reason) {
          case 'new':        return 'New';
          case 'new_report': return 'Report';
          case 'summary':    return 'Updated';
          default:           return 'Updated';
        }
      },
      updates() {
        // Recent updates: accessibility (status) changes only, detected within the last 7 days
        // AND whose driving report is no more than 2 weeks old (the displayed date). Sorted
        // newest-first by that report date; changed_at is the refresh-run day and ties for
        // everything flipped in the same run, so it can't order the list on its own.
        const isStatusChange = (t) =>
          t.status.change_reason === 'accessibility' ||
          (!t.status.change_reason && t.status.prev_accessibility);
        return this.trails
          .filter(t => t.status.is_recently_changed
            && (t.status.days_since_change ?? 99) <= 7
            && (t.status.days_since_report ?? 9999) <= 14
            && isStatusChange(t))
          .sort((a, b) => (a.status.days_since_report ?? 99999) - (b.status.days_since_report ?? 99999));
      },
      alreadyHave(r) {
        return this.trails.some(t => t.slug === r.slug);
      },
      countBy(field, value) {
        // For accessibility, exclude stale trails so the pill count matches the
        // filtered result (which also excludes stale).
        if (field === 'accessibility') {
          return this.trails.filter(t => t.status[field] === value && !t.status.is_stale).length;
        }
        return this.trails.filter(t => t.status[field] === value).length;
      },
      visible() {
        let out = this.trails.slice();
        if (this.access !== 'all') {
          // Stale trails are shown as gray "Stale" regardless of their last-known
          // accessibility — exclude them when the user explicitly filtered by a
          // specific status (Open / Snow gear / Closed).
          out = out.filter(t => t.status.accessibility === this.access && !t.status.is_stale);
        }
        if (this.region !== 'all') out = out.filter(t => t.region === this.region);
        if (this.maxDrive > 0) {
          out = out.filter(t => {
            const md = this.minDrive(t);
            return md != null && md <= this.maxDrive;
          });
        }
        const q = (this.query || '').trim().toLowerCase();
        if (q) {
          out = out.filter(t =>
            t.name.toLowerCase().includes(q) ||
            (t.subregion || '').toLowerCase().includes(q)
          );
        }
        const key = {
          rating: t => -t.rating,
          recent: t => t.status.last_report_date ? -new Date(t.status.last_report_date).getTime() : 0,
          drive:  t => this.minDrive(t) ?? Number.MAX_SAFE_INTEGER,
          volume: t => -t.votes,
          name:   t => t.name.toLowerCase(),
        }[this.sort];
        out.sort((a,b) => {
          const ka = key(a), kb = key(b);
          return ka < kb ? -1 : ka > kb ? 1 : 0;
        });
        return out;
      },
      visibleCount() { return this.visible().length; },
    };
  }
</script>

</body>
</html>
